INSTALL EXTENSION sdk_coverage;
# InValue::Int dispatch
SELECT sdk_identity_int(42);
sdk_identity_int(42)
42
SELECT sdk_identity_int(-100);
sdk_identity_int(-100)
-100
SELECT sdk_identity_int(NULL);
sdk_identity_int(NULL)
NULL
# InValue::Real dispatch
SELECT sdk_identity_real(1.5);
sdk_identity_real(1.5)
1.5
SELECT sdk_identity_real(-2.5);
sdk_identity_real(-2.5)
-2.5
SELECT sdk_identity_real(NULL);
sdk_identity_real(NULL)
NULL
# VdfReturn::Warning: negative returns NULL, non-negative returns value
SELECT sdk_warn_if_negative(10);
sdk_warn_if_negative(10)
10
SELECT sdk_warn_if_negative(0);
sdk_warn_if_negative(0)
0
SELECT sdk_warn_if_negative(-5);
sdk_warn_if_negative(-5)
NULL
Warnings:
Warning	3200	VDF error in function 'sdk_warn_if_negative': sdk_warn_if_negative: -5 is negative
SELECT sdk_warn_if_negative(NULL);
sdk_warn_if_negative(NULL)
NULL
# Type: counter (i64, decimal string)
SELECT counter::from_string('42');
counter::from_string('42')
42
SELECT counter::from_string('-7');
counter::from_string('-7')
-7
SELECT counter::from_string(NULL);
counter::from_string(NULL)
NULL
SELECT counter::from_string('not-a-number');
ERROR HY000: VDF error in function 'counter::from_string': counter: invalid digit found in string
SELECT counter::compare(counter::from_string('1'), counter::from_string('2'));
counter::compare(counter::from_string('1'), counter::from_string('2'))
-1
SELECT counter::compare(counter::from_string('5'), counter::from_string('5'));
counter::compare(counter::from_string('5'), counter::from_string('5'))
0
SELECT counter::compare(counter::from_string('9'), counter::from_string('3'));
counter::compare(counter::from_string('9'), counter::from_string('3'))
1
# Type: flag (bool, "true"/"false")
SELECT flag::from_string('true');
flag::from_string('true')
true
SELECT flag::from_string('false');
flag::from_string('false')
false
SELECT flag::from_string(NULL);
flag::from_string(NULL)
NULL
SELECT flag::from_string('maybe');
ERROR HY000: VDF error in function 'flag::from_string': flag: expected 'true' or 'false', got "maybe"
SELECT flag::compare(flag::from_string('false'), flag::from_string('true'));
flag::compare(flag::from_string('false'), flag::from_string('true'))
-1
SELECT flag::compare(flag::from_string('true'), flag::from_string('true'));
flag::compare(flag::from_string('true'), flag::from_string('true'))
0
SELECT flag::compare(flag::from_string('true'), flag::from_string('false'));
flag::compare(flag::from_string('true'), flag::from_string('false'))
1
# Two types in one extension: ORDER BY counter then flag
CREATE TABLE t1 (id INT, c counter, f flag);
INSERT INTO t1 VALUES (1, '10', 'true'), (2, '3', 'false'), (3, '10', 'false');
SELECT id, c, f FROM t1 ORDER BY id;
id	c	f
1	10	true
2	3	false
3	10	false
SELECT id, c, f FROM t1 ORDER BY c, f;
id	c	f
2	3	false
3	10	false
1	10	true
DROP TABLE t1;
# Default values: omitted columns use the registered default
CREATE TABLE t2 (id INT, c counter, f flag);
INSERT INTO t2 (id) VALUES (1);
SELECT id, c, f FROM t2;
id	c	f
1	NULL	NULL
DROP TABLE t2;
UNINSTALL EXTENSION sdk_coverage;
