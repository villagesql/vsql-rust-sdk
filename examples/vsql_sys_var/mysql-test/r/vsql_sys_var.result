SET PERSIST vsql_allow_preview_extensions = ON;
INSTALL EXTENSION vsql_sys_var;
# BOOL: default is ON, and setting it fires the on_change callback
SELECT @@global.vsql_sys_var.enabled;
@@global.vsql_sys_var.enabled
1
SELECT vsql_sys_var.change_count();
vsql_sys_var.change_count()
0
SET GLOBAL vsql_sys_var.enabled = 0;
SELECT @@global.vsql_sys_var.enabled;
@@global.vsql_sys_var.enabled
0
SELECT vsql_sys_var.change_count();
vsql_sys_var.change_count()
1
SET GLOBAL vsql_sys_var.enabled = 1;
SELECT vsql_sys_var.change_count();
vsql_sys_var.change_count()
2
# INT: default is 1000
SELECT @@global.vsql_sys_var.threshold;
@@global.vsql_sys_var.threshold
1000
# Read it back through the Rust get() accessor (not SQL)
SELECT vsql_sys_var.read_threshold();
vsql_sys_var.read_threshold()
1000
# Set it to 500 through the Rust set() accessor, then confirm via SQL and get()
SELECT vsql_sys_var.set_threshold_500();
vsql_sys_var.set_threshold_500()
1
SELECT @@global.vsql_sys_var.threshold;
@@global.vsql_sys_var.threshold
500
SELECT vsql_sys_var.read_threshold();
vsql_sys_var.read_threshold()
500
# STRING: default path, settable to a new value
SELECT @@global.vsql_sys_var.log_path;
@@global.vsql_sys_var.log_path
/tmp/vsql_sys_var.log
SET GLOBAL vsql_sys_var.log_path = '/var/log/custom.log';
SELECT @@global.vsql_sys_var.log_path;
@@global.vsql_sys_var.log_path
/var/log/custom.log
UNINSTALL EXTENSION vsql_sys_var;
# After UNINSTALL the variables are no longer registered
SELECT @@global.vsql_sys_var.enabled;
ERROR HY000: Unknown system variable 'vsql_sys_var.enabled'
SET PERSIST vsql_allow_preview_extensions = OFF;
RESET PERSIST vsql_allow_preview_extensions;
