INSTALL EXTENSION vsql_rot13;

--echo # Basic ASCII rotation
SELECT rot13('Hello, World!');

--echo # rot13 is its own inverse
SELECT rot13(rot13('Hello, World!'));

--echo # Uppercase and lowercase handled independently
SELECT rot13('ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz');

--echo # Numbers and punctuation pass through unchanged
SELECT rot13('abc123!@#');

--echo # Empty string
SELECT rot13('');

--echo # NULL input produces NULL output
SELECT rot13(NULL);

--echo # Works over a table column
CREATE TABLE t1 (s VARCHAR(100));
INSERT INTO t1 VALUES ('Hello'), ('World'), (NULL), ('rot13 test 123');
SELECT rot13(s) FROM t1 ORDER BY s;
DROP TABLE t1;

UNINSTALL EXTENSION vsql_rot13;
