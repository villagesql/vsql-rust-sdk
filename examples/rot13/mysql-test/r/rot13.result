INSTALL EXTENSION rot13;
# Basic ASCII rotation
SELECT vsql_rot13('Hello, World!');
vsql_rot13('Hello, World!')
Uryyb, Jbeyq!
# rot13 is its own inverse
SELECT vsql_rot13(vsql_rot13('Hello, World!'));
vsql_rot13(vsql_rot13('Hello, World!'))
Hello, World!
# Uppercase and lowercase handled independently
SELECT vsql_rot13('ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz');
vsql_rot13('ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz')
NOPQRSTUVWXYZABCDEFGHIJKLMnopqrstuvwxyzabcdefghijklm
# Numbers and punctuation pass through unchanged
SELECT vsql_rot13('abc123!@#');
vsql_rot13('abc123!@#')
nop123!@#
# Empty string
SELECT vsql_rot13('');
vsql_rot13('')

# NULL input produces NULL output
SELECT vsql_rot13(NULL);
vsql_rot13(NULL)
NULL
# Works over a table column
CREATE TABLE t1 (s VARCHAR(100));
INSERT INTO t1 VALUES ('Hello'), ('World'), (NULL), ('rot13 test 123');
SELECT vsql_rot13(s) FROM t1 ORDER BY s;
vsql_rot13(s)
NULL
Uryyb
ebg13 grfg 123
Jbeyq
DROP TABLE t1;
UNINSTALL EXTENSION rot13;
